{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personal-task-web-app",
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "personal-task-web-app"
    }
  ]
}